# Keep project dependency caches and build output inside this workspace.
# Linux / macOS:
#   export CARGO_HOME="$PWD/.cargo-home"
#   export CARGO_TARGET_DIR="$PWD/target"
#   export PROOFGATE_POLICY_PATH="$PWD/config/policy.sample.json"
#   export PROOFGATE_MAPPING_LOG="$PWD/data/local-mappings.jsonl"
#   export PROOFGATE_AUDIT_LOG="$PWD/data/audit.jsonl"
#   export PROOFGATE_AUDIT_POSTGRES_URL=""
#   export PROOFGATE_HMAC_KEY="replace-with-local-secret"
#
# Windows PowerShell:
#   $env:CARGO_HOME="E:\CodeHub\ProofGate\.cargo-home"
#   $env:RUSTUP_HOME="E:\CodeHub\ProofGate\.rustup-home"
#   $env:CARGO_TARGET_DIR="E:\CodeHub\ProofGate\target"
#   $env:PROOFGATE_POLICY_PATH="E:\CodeHub\ProofGate\config\policy.sample.json"
#   $env:PROOFGATE_MAPPING_LOG="E:\CodeHub\ProofGate\data\local-mappings.jsonl"
#   $env:PROOFGATE_AUDIT_LOG="E:\CodeHub\ProofGate\data\audit.jsonl"
#   $env:PROOFGATE_AUDIT_POSTGRES_URL=""
#   $env:PROOFGATE_HMAC_KEY="replace-with-local-secret"
#
# cmd.exe:
#   set CARGO_HOME=E:\CodeHub\ProofGate\.cargo-home
#   set RUSTUP_HOME=E:\CodeHub\ProofGate\.rustup-home
#   set CARGO_TARGET_DIR=E:\CodeHub\ProofGate\target
#   set PROOFGATE_POLICY_PATH=E:\CodeHub\ProofGate\config\policy.sample.json
#   set PROOFGATE_MAPPING_LOG=E:\CodeHub\ProofGate\data\local-mappings.jsonl
#   set PROOFGATE_AUDIT_LOG=E:\CodeHub\ProofGate\data\audit.jsonl
#   set PROOFGATE_AUDIT_POSTGRES_URL=
#   set PROOFGATE_HMAC_KEY=replace-with-local-secret

CARGO_HOME=.cargo-home
CARGO_TARGET_DIR=target
PROOFGATE_POLICY_PATH=config/policy.sample.json
PROOFGATE_MAPPING_LOG=data/local-mappings.jsonl
PROOFGATE_AUDIT_LOG=data/audit.jsonl
PROOFGATE_AUDIT_POSTGRES_URL=
PROOFGATE_HMAC_KEY=replace-with-local-secret

# External API simulation. These endpoints are allowed to receive only synthetic test data.
LOCAL_MODEL_BASE_URL=https://example-local-compatible-api/v1
LOCAL_MODEL_API_KEY=replace-with-local-simulation-key
LOCAL_MODEL_NAME=replace-with-local-simulation-model
EXTERNAL_MODEL_BASE_URL=https://example-external-compatible-api/v1
EXTERNAL_MODEL_API_KEY=replace-with-external-simulation-key
EXTERNAL_MODEL_NAME=replace-with-external-simulation-model

# Keep project dependency caches and build output inside this workspace.
# Linux / macOS:
#   export CARGO_HOME="$PWD/.cargo-home"
#   export CARGO_TARGET_DIR="$PWD/target"
#   export PRIVAGATE_POLICY_PATH="$PWD/config/policy.sample.json"
#   export PRIVAGATE_MAPPING_LOG="$PWD/data/local-mappings.jsonl"
#   export PRIVAGATE_AUDIT_LOG="$PWD/data/audit.jsonl"
#   export PRIVAGATE_AUDIT_POSTGRES_URL=""
#   export PRIVAGATE_REVIEW_LOG="$PWD/data/manual-review.jsonl"
#   export PRIVAGATE_REVIEW_POSTGRES_URL=""
#   export PRIVAGATE_REVIEW_MODE="off"
#   export PRIVAGATE_MODEL_ADAPTER="disabled"
#   export PRIVAGATE_HMAC_KEY="replace-with-local-secret"
#
# Windows PowerShell:
#   $env:CARGO_HOME="E:\CodeHub\PrivaGate\.cargo-home"
#   $env:RUSTUP_HOME="E:\CodeHub\PrivaGate\.rustup-home"
#   $env:CARGO_TARGET_DIR="E:\CodeHub\PrivaGate\target"
#   $env:PRIVAGATE_POLICY_PATH="E:\CodeHub\PrivaGate\config\policy.sample.json"
#   $env:PRIVAGATE_MAPPING_LOG="E:\CodeHub\PrivaGate\data\local-mappings.jsonl"
#   $env:PRIVAGATE_AUDIT_LOG="E:\CodeHub\PrivaGate\data\audit.jsonl"
#   $env:PRIVAGATE_AUDIT_POSTGRES_URL=""
#   $env:PRIVAGATE_REVIEW_LOG="E:\CodeHub\PrivaGate\data\manual-review.jsonl"
#   $env:PRIVAGATE_REVIEW_POSTGRES_URL=""
#   $env:PRIVAGATE_REVIEW_MODE="off"
#   $env:PRIVAGATE_MODEL_ADAPTER="disabled"
#   $env:PRIVAGATE_HMAC_KEY="replace-with-local-secret"
#
# cmd.exe:
#   set CARGO_HOME=E:\CodeHub\PrivaGate\.cargo-home
#   set RUSTUP_HOME=E:\CodeHub\PrivaGate\.rustup-home
#   set CARGO_TARGET_DIR=E:\CodeHub\PrivaGate\target
#   set PRIVAGATE_POLICY_PATH=E:\CodeHub\PrivaGate\config\policy.sample.json
#   set PRIVAGATE_MAPPING_LOG=E:\CodeHub\PrivaGate\data\local-mappings.jsonl
#   set PRIVAGATE_AUDIT_LOG=E:\CodeHub\PrivaGate\data\audit.jsonl
#   set PRIVAGATE_AUDIT_POSTGRES_URL=
#   set PRIVAGATE_REVIEW_LOG=E:\CodeHub\PrivaGate\data\manual-review.jsonl
#   set PRIVAGATE_REVIEW_POSTGRES_URL=
#   set PRIVAGATE_REVIEW_MODE=off
#   set PRIVAGATE_MODEL_ADAPTER=disabled
#   set PRIVAGATE_HMAC_KEY=replace-with-local-secret

CARGO_HOME=.cargo-home
CARGO_TARGET_DIR=target
PRIVAGATE_POLICY_PATH=config/policy.sample.json
PRIVAGATE_MAPPING_LOG=data/local-mappings.jsonl
PRIVAGATE_AUDIT_LOG=data/audit.jsonl
PRIVAGATE_AUDIT_POSTGRES_URL=
PRIVAGATE_REVIEW_LOG=data/manual-review.jsonl
PRIVAGATE_REVIEW_POSTGRES_URL=
PRIVAGATE_REVIEW_MODE=off
PRIVAGATE_MODEL_ADAPTER=disabled
PRIVAGATE_HMAC_KEY=replace-with-local-secret

# External API simulation. These endpoints are allowed to receive only synthetic test data.
LOCAL_MODEL_BASE_URL=https://example-local-compatible-api/v1
LOCAL_MODEL_API_KEY=replace-with-local-simulation-key
LOCAL_MODEL_NAME=replace-with-local-simulation-model
EXTERNAL_MODEL_BASE_URL=https://example-external-compatible-api/v1
EXTERNAL_MODEL_API_KEY=replace-with-external-simulation-key
EXTERNAL_MODEL_NAME=replace-with-external-simulation-model
